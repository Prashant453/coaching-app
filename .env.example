# ===================================
# Server Configuration
# ===================================
PORT=5000
NODE_ENV=development

# ===================================
# Database (Supabase PostgreSQL)
# ===================================
# Use Supabase connection pooler URL (port 6543)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ===================================
# JWT Authentication
# ===================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ===================================
# Razorpay (India Payments)
# ===================================
RAZORPAY_KEY_ID=rzp_test_SMSUJaF8QXfBY8
RAZORPAY_KEY_SECRET=AHSLp6R2r70BpFiI5YCfZZRY

# ===================================
# Admin Credentials (Initial Setup)
# ===================================
ADMIN_EMAIL=admin@coaching.com
ADMIN_PASSWORD=change_this_password

# ===================================
# Frontend URL (CORS)
# ===================================
FRONTEND_URL=https://coaching-admin-bay.vercel.app/
